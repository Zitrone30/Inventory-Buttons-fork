{
	"schemaVersion": 1,
	"id": "inventorybuttons",
	"version": "${version}",
	"name": "inventorybuttons",
	"description": "Adds customizable inventory action buttons inspired by NotEnoughUpdates.",
	"authors": [
		"afranz29"
	],
	"contact": {
		"homepage": "https://github.com/afranz29/Inventory-Buttons",
		"sources": "https://github.com/afranz29/Inventory-Buttons"
	},
	"license": "LGPL-3.0-only",
	"icon": "assets/inventorybuttons/icon.png",
	"environment": "*",
	"entrypoints": {
		"client": [
			"com.panda.inventorybuttons.InventoryButtonsClient"
		]
	},
	"mixins": [
		"inventorybuttons.mixins.json",
		{
			"config": "inventorybuttons.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "~1.21.8",
		"java": ">=21",
		"fabric-api": "*"
	}
}
